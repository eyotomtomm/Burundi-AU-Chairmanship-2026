# =============================================================================
# Burundi AU Chairmanship — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# For DigitalOcean App Platform, set these in the dashboard as encrypted vars.
#
# Generate SECRET_KEY with:
#   python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# =============================================================================

# ─── Django Core ──────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.burundi4africa.com,burundi4africa.com,www.burundi4africa.com

# ─── Database (PostgreSQL) ────────────────────────────────────
# DigitalOcean managed DB provides this automatically as ${db.DATABASE_URL}
DATABASE_URL=postgresql://user:password@host:25060/burundi_au_db?sslmode=require

# ─── Site URL (used for building full media URLs) ─────────────
SITE_URL=https://api.burundi4africa.com

# ─── Email via Google Workspace SMTP ──────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@burundi4africa.com
EMAIL_HOST_PASSWORD=your-google-workspace-app-password
DEFAULT_FROM_EMAIL=Burundi AU Chairmanship <noreply@burundi4africa.com>

# ─── Twilio SMS (for phone OTP verification) ──────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_SENDER_ID=B4africa

# ─── DigitalOcean Spaces (S3-compatible media storage) ────────
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_BUCKET=burundi-au-media
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com

# ─── Firebase Admin SDK ──────────────────────────────────────
# Path to the service account JSON key file
FIREBASE_CREDENTIALS_PATH=/app/credentials/firebase-adminsdk.json

# ─── Sentry Error Tracking ───────────────────────────────────
SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/1234567
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=burundi-au-backend@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1
