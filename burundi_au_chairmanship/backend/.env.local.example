# Local Development Environment Variables
# Copy this file to .env.local and fill in your values
# .env.local is in .gitignore and won't be committed

# Django Settings
DJANGO_SECRET_KEY=django-insecure-local-dev-key-generate-your-own
# IMPORTANT: Must explicitly set to True for development
DJANGO_DEBUG=True
# ALLOWED_HOSTS not needed for DEBUG=True (defaults to localhost, 127.0.0.1, [::1])
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite is default for local dev)
# Uncomment to use PostgreSQL locally:
# DATABASE_URL=postgresql://user:password@localhost:5432/burundi_au_dev

# Firebase (optional for local dev)
# FIREBASE_CREDENTIALS_PATH=./config/firebase-adminsdk-local.json

# DigitalOcean Spaces (not needed for local dev - uses local media folder)
# DO_SPACES_KEY=
# DO_SPACES_SECRET=
# DO_SPACES_BUCKET=
# DO_SPACES_ENDPOINT=

# To generate a secure SECRET_KEY:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
