# =============================================================================
# Be 4 Africa — DigitalOcean Production Environment Variables
# =============================================================================
#
# RECOVERY SETUP:
# These values go into the DigitalOcean App Platform dashboard as environment
# variables. Items marked [FILL IN] need values from your new DO setup.
#
# =============================================================================

# ─── Django Core ──────────────────────────────────────────────
# Generate a NEW production secret key with:
#   python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.burundi4africa.com,burundi4africa.com,www.burundi4africa.com

# ─── Database (PostgreSQL) ────────────────────────────────────
# This is auto-provided by DigitalOcean when you attach a managed DB.
# In the app.yaml it's referenced as ${db.DATABASE_URL}
# If setting manually, the format is:
DATABASE_URL=postgresql://user:password@host:25060/dbname?sslmode=require

# ─── Site URL ─────────────────────────────────────────────────
SITE_URL=https://burundi4africa.com

# ─── Email via Google Workspace SMTP ──────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@burundi4africa.com
EMAIL_HOST_PASSWORD=your-google-workspace-app-password
DEFAULT_FROM_EMAIL=Be 4 Africa <info@burundi4africa.com>

# ─── Twilio SMS & WhatsApp OTP ────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SENDER_ID=B4africa
TWILIO_PHONE_NUMBER=+1234567890

# ─── DigitalOcean Spaces (S3-compatible media storage) ────────
# Create a new Spaces bucket + API key in DO dashboard:
#   1. Go to Spaces Object Storage > Create Bucket
#      - Name: burundi-au-media
#      - Region: Frankfurt (fra1)
#   2. Go to API > Spaces Keys > Generate New Key
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_BUCKET=burundi-au-media
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com

# ─── Firebase Admin SDK ──────────────────────────────────────
# For DigitalOcean, paste the ENTIRE firebase-adminsdk.json as a single line.
# Your firebase-adminsdk.json is at: backend/config/firebase-adminsdk.json
# To convert to single line for the DO dashboard:
#   cat backend/config/firebase-adminsdk.json | python -c "import sys,json; print(json.dumps(json.load(sys.stdin)))"
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"your-private-key-id","private_key":"-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project-id.iam.gserviceaccount.com","client_id":"000000000000000000000","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40your-project-id.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# ─── Sentry Error Tracking ───────────────────────────────────
SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/1234567
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=burundi-au-backend@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_ORG=burundi-embassy-pu
SENTRY_PROJECT=b4africa-backend
SENTRY_AUTH_TOKEN=
